generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId      String   @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")

  watchEntries WatchEntry[]
  userQuests   UserQuest[]

  @@map("users")
}

model Anime {
  animeId          String   @id @default(dbgenerated("gen_random_uuid()")) @map("anime_id") @db.Uuid
  provider         String
  providerId       String   @map("provider_id")
  title            String
  genres           String[] @default([])
  episodes         Int?
  year             Int?
  trailerYoutubeId String?  @map("trailer_youtube_id")
  createdAt        DateTime @default(now()) @map("created_at")

  watchEntries WatchEntry[]

  @@unique([provider, providerId])
  @@map("anime")
}

model Quest {
  questId      String   @id @default(dbgenerated("gen_random_uuid()")) @map("quest_id") @db.Uuid
  code         String   @unique
  title        String
  description  String
  requirements Json
  rewards      Json
  createdAt    DateTime @default(now()) @map("created_at")

  userQuests UserQuest[]

  @@map("quests")
}

model UserQuest {
  userId    String   @map("user_id") @db.Uuid
  questId   String   @map("quest_id") @db.Uuid
  status    String
  progress  Json     @default("{}")
  updatedAt DateTime @default(now()) @map("updated_at")

  user  User  @relation(fields: [userId], references: [userId])
  quest Quest @relation(fields: [questId], references: [questId])

  @@id([userId, questId])
  @@map("user_quests")
}

model WatchEntry {
  userId          String   @map("user_id") @db.Uuid
  animeId         String   @map("anime_id") @db.Uuid
  status          String
  score           Int?
  episodesWatched Int      @default(0) @map("episodes_watched")
  updatedAt       DateTime @default(now()) @map("updated_at")

  user  User  @relation(fields: [userId], references: [userId])
  anime Anime @relation(fields: [animeId], references: [animeId])

  @@id([userId, animeId])
  @@map("watch_entries")
}
